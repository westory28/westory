rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAllowedSchoolEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@yongshin-ms\\.ms\\.kr$');
    }

    function canUseWestory() {
      return isSignedIn()
        && (hasAllowedSchoolEmail() || request.auth.token.email == "westoria28@gmail.com");
    }

    function isAdmin() {
      return canUseWestory() && request.auth.token.email == "westoria28@gmail.com";
    }

    function hasUserProfile() {
      return canUseWestory()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userProfile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function hasStoragePermission(permission) {
      return hasUserProfile()
        && userProfile().teacherPortalEnabled == true
        && userProfile().staffPermissions is list
        && permission in userProfile().staffPermissions;
    }

    function isTeacherRole() {
      return hasUserProfile() && userProfile().role == "teacher";
    }

    function canReadSourceArchive() {
      return isAdmin() || isTeacherRole() || hasStoragePermission('lesson_read');
    }

    function canWriteSourceArchive() {
      return isAdmin() || isTeacherRole();
    }

    function isLessonPdfAssetUpload() {
      return request.resource != null
        && request.resource.contentType is string
        && (
          (
            request.resource.contentType == 'application/pdf'
            && request.resource.size < 20 * 1024 * 1024
          )
          || (
            request.resource.contentType.matches('image/.*')
            && request.resource.size < 6 * 1024 * 1024
          )
        );
    }

    function isSafeLessonPdfWrite() {
      return request.resource == null || isLessonPdfAssetUpload();
    }

    match /map-resources/{resourceId}/{allPaths=**} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /lesson_pdfs/{unitId}/{allPaths=**} {
      allow read: if canUseWestory();
      allow write: if isAdmin() && isSafeLessonPdfWrite();
    }

    match /years/{year}/semesters/{semester}/lesson_pdfs/{unitId}/{allPaths=**} {
      allow read: if canUseWestory();
      allow write: if isAdmin() && isSafeLessonPdfWrite();
    }

    match /years/{year}/semesters/{semester}/lesson_footnotes/{unitId}/{allPaths=**} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /years/{year}/semesters/{semester}/notice_images/{noticeId}/{fileName} {
      allow read: if canUseWestory();
      allow write: if isAdmin()
        && request.resource != null
        && request.resource.contentType is string
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 700 * 1024;
    }

    match /years/{year}/semesters/{semester}/point_products/{productId}/{allPaths=**} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /site-settings/interface/hall-of-fame/{allPaths=**} {
      allow read: if canUseWestory();
      allow write: if isAdmin() || isTeacherRole() || hasStoragePermission('point_manage');
    }

    match /site-settings/interface/{allPaths=**} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /source-archive/{assetId}/incoming/{fileName} {
      allow read: if false;
      allow write: if canWriteSourceArchive()
        && request.resource != null
        && request.resource.contentType is string
        && (
          (
            request.resource.contentType.matches('image/.*')
            && request.resource.size < 6 * 1024 * 1024
          )
          || (
            request.resource.contentType == 'application/pdf'
            && request.resource.size < 20 * 1024 * 1024
          )
        );
    }

    // Processed assets live under a revision folder. Keep incoming uploads private.
    match /source-archive/{assetId}/{revision}/{fileName} {
      allow read: if canReadSourceArchive() && revision != 'incoming';
      allow write: if false;
    }
  }
}
