rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasAllowedSchoolEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@yongshin-ms\\.ms\\.kr$');
    }

    function canUseWestory() {
      return isSignedIn() && (hasAllowedSchoolEmail() || request.auth.token.email == "westoria28@gmail.com");
    }

    function isAdmin() {
      return canUseWestory() && request.auth.token.email == "westoria28@gmail.com";
    }

    function isOwnUser(userId) {
      return canUseWestory() && request.auth.uid == userId;
    }

    function hasUserProfile() {
      return canUseWestory() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasPermission(permission) {
      return hasUserProfile()
        && userProfile().teacherPortalEnabled == true
        && userProfile().staffPermissions is list
        && permission in userProfile().staffPermissions;
    }

    function userGrade() {
      return userProfile().grade;
    }

    function userClass() {
      return userProfile().class;
    }

    function canAccessThinkCloudTarget(targetGrade, targetClass) {
      return isAdmin()
        || (canUseWestory()
          && hasUserProfile()
          && targetGrade == userGrade()
          && targetClass == userClass());
    }

    function canReadPointData() {
      return isAdmin() || hasPermission('point_read') || hasPermission('point_manage');
    }

    function canManagePointData() {
      return isAdmin() || hasPermission('point_manage');
    }

    function isTeacherRole() {
      return hasUserProfile() && userProfile().role == 'teacher';
    }

    function isStudentRole() {
      return hasUserProfile() && userProfile().role == 'student';
    }

    function developerLogLikePath(logId) {
      return /databases/$(database)/documents/developer_logs/$(logId)/likes/$(request.auth.uid);
    }

    function isDeveloperLogViewUpdate() {
      return canUseWestory()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount == resource.data.viewCount + 1;
    }

    function isDeveloperLogLikeCountUpdate(logId) {
      return canUseWestory()
        && isStudentRole()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])
        && (
          (
            request.resource.data.likeCount == resource.data.likeCount + 1
            && !exists(developerLogLikePath(logId))
            && existsAfter(developerLogLikePath(logId))
          )
          || (
            request.resource.data.likeCount == resource.data.likeCount - 1
            && exists(developerLogLikePath(logId))
            && !existsAfter(developerLogLikePath(logId))
          )
        );
    }

    function canReadQuizResult(data) {
      return canUseWestory()
        && (
          data.uid == request.auth.uid
          || isAdmin()
          || isTeacherRole()
          || hasPermission('quiz_read')
        );
    }

    function canReadQuizSubmission(data) {
      return canUseWestory()
        && (
          data.uid == request.auth.uid
          || isAdmin()
          || isTeacherRole()
          || hasPermission('quiz_read')
        );
    }

    function isAssignedHistoryClassroomStudent(data) {
      return canUseWestory()
        && (
          (
            data.keys().hasAny(['targetStudentUid'])
            && data.targetStudentUid == request.auth.uid
          )
          || (
            data.keys().hasAny(['targetStudentAccessMap'])
            && data.targetStudentAccessMap is map
            && data.targetStudentAccessMap[request.auth.uid] == true
          )
          || (
            data.keys().hasAny(['targetStudentUids'])
            && data.targetStudentUids is list
            && request.auth.uid in data.targetStudentUids
          )
        );
    }

    function canReadHistoryClassroomResource(data) {
      return isAdmin() || isTeacherRole() || isAssignedHistoryClassroomStudent(data);
    }

    function canWriteHistoryClassroomResource() {
      return isAdmin() || isTeacherRole();
    }

    function canReadHistoryClassroomResult(data) {
      return isAdmin()
        || isTeacherRole()
        || (canUseWestory() && data.uid == request.auth.uid);
    }

    function canReadSourceArchive() {
      return isAdmin() || isTeacherRole() || hasPermission('lesson_read');
    }

    function canWriteSourceArchive() {
      return isAdmin() || isTeacherRole();
    }

    function canReadHistoryDictionaryRequest(data) {
      return canUseWestory()
        && (
          data.uid == request.auth.uid
          || isAdmin()
          || isTeacherRole()
          || hasPermission('lesson_read')
        );
    }

    function canReadOwnPointResource(targetUid) {
      return canUseWestory() && targetUid == request.auth.uid;
    }

    function changedUserKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function hasOnlyUserDocKeys() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'photoURL',
        'role',
        'staffPermissions',
        'teacherPortalEnabled',
        'name',
        'customNameConfirmed',
        'grade',
        'class',
        'number',
        'privacyAgreed',
        'privacyAgreedAt',
        'consentAgreedItems',
        'profileIcon',
        'profileEmojiId',
        'myPageGoalScore',
        'myPageSubjectGoals',
        'scoreWarningAcknowledged',
        'scoreWarningAcknowledgedAt',
        'createdAt',
        'updatedAt',
        'lastLogin'
      ]);
    }

    function hasValidOwnUserFieldTypes() {
      return (!request.resource.data.keys().hasAny(['uid']) || (request.resource.data.uid is string && request.resource.data.uid == request.auth.uid))
        && (!request.resource.data.keys().hasAny(['email']) || (request.resource.data.email is string && request.resource.data.email == request.auth.token.email))
        && (!request.resource.data.keys().hasAny(['photoURL']) || request.resource.data.photoURL is string)
        && (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role in ['student', 'staff', 'teacher'])
        && (!request.resource.data.keys().hasAny(['teacherPortalEnabled']) || request.resource.data.teacherPortalEnabled is bool)
        && (!request.resource.data.keys().hasAny(['staffPermissions']) || request.resource.data.staffPermissions is list)
        && (!request.resource.data.keys().hasAny(['name']) || (request.resource.data.name is string && request.resource.data.name.size() <= 20))
        && (!request.resource.data.keys().hasAny(['customNameConfirmed']) || request.resource.data.customNameConfirmed is bool)
        && (!request.resource.data.keys().hasAny(['grade']) || (request.resource.data.grade is string && request.resource.data.grade.size() <= 8))
        && (!request.resource.data.keys().hasAny(['class']) || (request.resource.data.class is string && request.resource.data.class.size() <= 8))
        && (!request.resource.data.keys().hasAny(['number']) || (request.resource.data.number is string && request.resource.data.number.size() <= 8))
        && (!request.resource.data.keys().hasAny(['privacyAgreed']) || request.resource.data.privacyAgreed is bool)
        && (!request.resource.data.keys().hasAny(['consentAgreedItems']) || (
          request.resource.data.consentAgreedItems is list
          && request.resource.data.consentAgreedItems.size() <= 50
        ))
        && (!request.resource.data.keys().hasAny(['profileIcon']) || (request.resource.data.profileIcon is string && request.resource.data.profileIcon.size() <= 16))
        && (!request.resource.data.keys().hasAny(['profileEmojiId']) || (request.resource.data.profileEmojiId is string && request.resource.data.profileEmojiId.size() <= 64))
        && (!request.resource.data.keys().hasAny(['myPageGoalScore']) || (request.resource.data.myPageGoalScore is string && request.resource.data.myPageGoalScore.size() <= 120))
        && (!request.resource.data.keys().hasAny(['myPageSubjectGoals']) || (
          request.resource.data.myPageSubjectGoals is map
          && request.resource.data.myPageSubjectGoals.keys().size() <= 30
        ))
        && (!request.resource.data.keys().hasAny(['scoreWarningAcknowledged']) || request.resource.data.scoreWarningAcknowledged is bool);
    }

    function isValidOwnStudentCreate(userId) {
      return isOwnUser(userId)
        && hasOnlyUserDocKeys()
        && hasValidOwnUserFieldTypes()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'student'
        && (!request.resource.data.keys().hasAny(['teacherPortalEnabled']) || request.resource.data.teacherPortalEnabled == false)
        && (!request.resource.data.keys().hasAny(['staffPermissions']) || request.resource.data.staffPermissions.size() == 0);
    }

    function protectedUserFieldsUnchanged() {
      let requestTeacherPortalEnabled = request.resource.data.keys().hasAny(['teacherPortalEnabled'])
        ? request.resource.data.teacherPortalEnabled
        : false;
      let resourceTeacherPortalEnabled = resource.data.keys().hasAny(['teacherPortalEnabled'])
        ? resource.data.teacherPortalEnabled
        : false;
      let requestStaffPermissions = request.resource.data.keys().hasAny(['staffPermissions']) && request.resource.data.staffPermissions is list
        ? request.resource.data.staffPermissions
        : [];
      let resourceStaffPermissions = resource.data.keys().hasAny(['staffPermissions']) && resource.data.staffPermissions is list
        ? resource.data.staffPermissions
        : [];

      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && requestTeacherPortalEnabled == resourceTeacherPortalEnabled
        && requestStaffPermissions == resourceStaffPermissions;
    }

    function isValidOwnStudentUpdate(userId) {
      return isOwnUser(userId)
        && hasOnlyUserDocKeys()
        && hasValidOwnUserFieldTypes()
        && protectedUserFieldsUnchanged()
        && (
          changedUserKeys().hasOnly([
            'photoURL',
            'lastLogin',
            'updatedAt',
            'myPageGoalScore',
            'myPageSubjectGoals',
            'scoreWarningAcknowledged',
            'scoreWarningAcknowledgedAt',
            'privacyAgreed',
            'privacyAgreedAt',
            'consentAgreedItems'
          ])
          || (
            resource.data.role == 'student'
            && resource.data.customNameConfirmed != true
            && request.resource.data.customNameConfirmed == true
            && changedUserKeys().hasOnly([
              'photoURL',
              'lastLogin',
              'updatedAt',
              'privacyAgreed',
              'privacyAgreedAt',
              'consentAgreedItems',
              'name',
              'grade',
              'class',
              'number',
              'customNameConfirmed'
            ])
          )
        );
    }

    function isValidQuizResultCreate() {
      return canUseWestory()
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'class',
          'number',
          'gradeClass',
          'unitId',
          'category',
          'score',
          'details',
          'status',
          'timestamp',
          'timeString'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.class is string
        && request.resource.data.number is string
        && request.resource.data.gradeClass is string
        && request.resource.data.unitId is string
        && request.resource.data.category is string
        && request.resource.data.score is number
        && request.resource.data.details is list
        && request.resource.data.details.size() <= 200
        && request.resource.data.status is string
        && request.resource.data.timeString is string;
    }

    function hasOnlyQuizSubmissionKeys() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'name',
        'email',
        'class',
        'number',
        'gradeClass',
        'unitId',
        'category',
        'title',
        'status',
        'questionIds',
        'answers',
        'currentIndex',
        'hintUsedCount',
        'revealedHintIds',
        'orderOptionMap',
        'timeLimitSeconds',
        'clientStartedAtMs',
        'lastClientSavedAtMs',
        'startedAt',
        'lastSavedAt',
        'submittedAt',
        'resultId'
      ]);
    }

    function isValidQuizSubmissionPayload() {
      return hasOnlyQuizSubmissionKeys()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.class is string
        && request.resource.data.number is string
        && request.resource.data.gradeClass is string
        && request.resource.data.unitId is string
        && request.resource.data.category is string
        && request.resource.data.title is string
        && request.resource.data.status in ['in_progress', 'submitted', 'timed_out']
        && request.resource.data.questionIds is list
        && request.resource.data.questionIds.size() <= 100
        && request.resource.data.answers is map
        && request.resource.data.answers.keys().size() <= 200
        && request.resource.data.currentIndex is number
        && request.resource.data.hintUsedCount is number
        && request.resource.data.revealedHintIds is list
        && request.resource.data.revealedHintIds.size() <= 100
        && request.resource.data.orderOptionMap is map
        && request.resource.data.timeLimitSeconds is number
        && request.resource.data.clientStartedAtMs is number
        && request.resource.data.lastClientSavedAtMs is number
        && request.resource.data.startedAt is timestamp
        && request.resource.data.lastSavedAt is timestamp
        && (!request.resource.data.keys().hasAny(['submittedAt']) || request.resource.data.submittedAt is timestamp)
        && request.resource.data.resultId is string;
    }

    function isValidQuizSubmissionCreate() {
      return canUseWestory()
        && isValidQuizSubmissionPayload();
    }

    function isValidQuizSubmissionUpdate() {
      return canUseWestory()
        && (
          !resource.data.keys().hasAny(['uid'])
          || resource.data.uid == request.auth.uid
        )
        && (
          !resource.data.keys().hasAny(['unitId'])
          || request.resource.data.unitId == resource.data.unitId
        )
        && (
          !resource.data.keys().hasAny(['category'])
          || request.resource.data.category == resource.data.category
        )
        && isValidQuizSubmissionPayload();
    }

    function isValidHistoryClassroomResultCreate() {
      return canUseWestory()
        && request.resource.data.keys().hasOnly([
          'assignmentId',
          'assignmentTitle',
          'uid',
          'studentName',
          'studentGrade',
          'studentClass',
          'studentNumber',
          'answers',
          'score',
          'total',
          'percent',
          'passThresholdPercent',
          'passed',
          'status',
          'cancellationReason',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.assignmentId is string
        && request.resource.data.assignmentTitle is string
        && request.resource.data.studentName is string
        && request.resource.data.studentGrade is string
        && request.resource.data.studentClass is string
        && request.resource.data.studentNumber is string
        && request.resource.data.answers is map
        && request.resource.data.answers.keys().size() <= 200
        && request.resource.data.score is number
        && request.resource.data.total is number
        && request.resource.data.percent is number
        && request.resource.data.passThresholdPercent is number
        && request.resource.data.passed is bool
        && request.resource.data.status is string
        && request.resource.data.cancellationReason is string;
    }

    function isValidRootThinkCloudResponseCreate(sessionId) {
      return isSignedIn()
        && request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'textRaw',
          'textNormalized',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 20
        && request.resource.data.textRaw is string
        && request.resource.data.textRaw.size() <= 120
        && request.resource.data.textNormalized is string
        && request.resource.data.textNormalized.size() <= 120
        && canAccessThinkCloudTarget(
          get(/databases/$(database)/documents/think_cloud_sessions/$(sessionId)).data.targetGrade,
          get(/databases/$(database)/documents/think_cloud_sessions/$(sessionId)).data.targetClass
        )
        && get(/databases/$(database)/documents/think_cloud_sessions/$(sessionId)).data.status == 'active';
    }

    function isValidSemesterThinkCloudResponseCreate(year, semester, sessionId) {
      return isSignedIn()
        && request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'textRaw',
          'textNormalized',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 20
        && request.resource.data.textRaw is string
        && request.resource.data.textRaw.size() <= 120
        && request.resource.data.textNormalized is string
        && request.resource.data.textNormalized.size() <= 120
        && canAccessThinkCloudTarget(
          get(/databases/$(database)/documents/years/$(year)/semesters/$(semester)/think_cloud_sessions/$(sessionId)).data.targetGrade,
          get(/databases/$(database)/documents/years/$(year)/semesters/$(semester)/think_cloud_sessions/$(sessionId)).data.targetClass
        )
        && get(/databases/$(database)/documents/years/$(year)/semesters/$(semester)/think_cloud_sessions/$(sessionId)).data.status == 'active';
    }

    // 사용자 기본 문서 권한
    match /users/{userId} {
      allow get: if canUseWestory() && (isOwnUser(userId) || isAdmin() || hasPermission('student_list_read'));
      allow list: if isAdmin() || hasPermission('student_list_read');
      allow create: if isAdmin() || isValidOwnStudentCreate(userId);
      allow update: if isAdmin() || isValidOwnStudentUpdate(userId);
      allow delete: if isAdmin();

      match /academic_records/{recordId} {
        allow read: if canUseWestory() && (isOwnUser(userId) || isAdmin());
        allow create, update: if canUseWestory()
          && isOwnUser(userId)
          && request.resource.data.keys().hasOnly(['scores', 'updatedAt'])
          && request.resource.data.scores is map
          && request.resource.data.scores.keys().size() <= 500;
        allow delete: if canUseWestory() && (isOwnUser(userId) || isAdmin());
      }

      match /attendance/{recordId} {
        allow read: if canUseWestory() && (isOwnUser(userId) || isAdmin());
        allow create, update: if canUseWestory()
          && isOwnUser(userId)
          && request.resource.data.keys().hasOnly(['uid', 'scope', 'year', 'semester', 'date', 'checkedAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.scope is string
          && request.resource.data.year is string
          && request.resource.data.semester is string
          && request.resource.data.date is string;
        allow delete: if isAdmin();
      }

      match /history_dictionary_words/{wordId} {
        allow read: if canUseWestory()
          && (
            isOwnUser(userId)
            || isAdmin()
            || isTeacherRole()
            || hasPermission('lesson_read')
          );
        allow create, update, delete: if false;
      }
    }

    match /{path=**}/history_dictionary_words/{wordId} {
      allow read: if canUseWestory()
        && (
          isAdmin()
          || isTeacherRole()
          || hasPermission('lesson_read')
          || resource.data.uid == request.auth.uid
        );
      allow create, update, delete: if false;
    }

    match /site_settings/{docId} {
      allow read: if docId in ['terms', 'privacy', 'school_config', 'interface_config'] || canUseWestory();
      allow write: if isAdmin();

      match /items/{itemId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }
    }

    match /developer_logs/{logId} {
      allow read: if canUseWestory();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || isDeveloperLogViewUpdate()
        || isDeveloperLogLikeCountUpdate(logId);

      match /likes/{likeId} {
        allow read: if canUseWestory();
        allow create: if canUseWestory()
          && isStudentRole()
          && likeId == request.auth.uid
          && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
          && request.resource.data.uid == request.auth.uid;
        allow delete: if canUseWestory()
          && isStudentRole()
          && likeId == request.auth.uid;
        allow update: if false;
      }
    }

    match /metadata/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /curriculum/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /lessons/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /map_resources/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /source_archive/{docId} {
      allow read: if canReadSourceArchive();
      allow write: if canWriteSourceArchive();
    }

    match /history_dictionary_terms/{termId} {
      allow read: if canUseWestory();
      allow create, update, delete: if false;
    }

    match /history_dictionary_requests/{requestId} {
      allow read: if canReadHistoryDictionaryRequest(resource.data);
      allow create, update, delete: if false;
    }

    match /quiz_questions/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /history_classrooms/{docId} {
      allow read: if canReadHistoryClassroomResource(resource.data);
      allow write: if canWriteHistoryClassroomResource();
    }

    match /history_classroom_results/{docId} {
      allow read: if canReadHistoryClassroomResult(resource.data);
      allow create: if isValidHistoryClassroomResultCreate();
      allow update, delete: if isAdmin();
    }

    match /assessment_config/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin() || isTeacherRole();
    }

    match /grading_plans/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /exam_config/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /quiz_results/{resultId} {
      allow read: if canReadQuizResult(resource.data);
      allow create: if isValidQuizResultCreate();
      allow update, delete: if isAdmin();
    }

    match /quiz_submissions/{docId} {
      allow read: if canReadQuizSubmission(resource.data);
      allow create: if isAdmin() || isValidQuizSubmissionCreate();
      allow update: if isAdmin() || isValidQuizSubmissionUpdate();
      allow delete: if isAdmin();
    }

    match /think_cloud_state/{docId} {
      allow read: if canUseWestory();
      allow write: if isAdmin();
    }

    match /lesson_progress/{userId} {
      allow read, write: if canUseWestory() && (request.auth.uid == userId || isAdmin());

      match /units/{unitId} {
        allow read, write: if canUseWestory() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /think_cloud_sessions/{sessionId} {
      allow read: if canAccessThinkCloudTarget(resource.data.targetGrade, resource.data.targetClass) || hasPermission('lesson_read');
      allow create, update, delete: if isAdmin();

      match /responses/{responseId} {
        allow read: if canAccessThinkCloudTarget(
          get(/databases/$(database)/documents/think_cloud_sessions/$(sessionId)).data.targetGrade,
          get(/databases/$(database)/documents/think_cloud_sessions/$(sessionId)).data.targetClass
        );
        allow create: if isValidRootThinkCloudResponseCreate(sessionId);
        allow update, delete: if isAdmin();
      }
    }

    // 학년도/학기 범위 컬렉션 권한
    match /years/{year}/semesters/{semester} {
      match /point_public/{docId} {
        allow read: if canUseWestory() && docId == 'hall_of_fame';
        allow create, update, delete: if false;
      }

      match /point_wallets/{userId} {
        allow read: if canReadOwnPointResource(userId) || canReadPointData();
        allow create, update, delete: if false;
      }

      match /point_transactions/{txId} {
        allow read: if canReadOwnPointResource(resource.data.uid) || canReadPointData();
        allow create, update, delete: if false;
      }

      match /point_products/{productId} {
        allow read: if canUseWestory();
        allow create, update, delete: if canManagePointData();
      }

      match /point_orders/{orderId} {
        allow read: if canReadOwnPointResource(resource.data.uid) || canReadPointData();
        allow create, update, delete: if false;
      }

      match /point_policies/{policyId} {
        allow read: if canUseWestory();
        allow create, update, delete: if canManagePointData();
      }

      match /notification_inboxes/{userId} {
        allow read: if canReadOwnPointResource(userId);
        allow create, update, delete: if false;

        match /items/{notificationId} {
          allow read: if canReadOwnPointResource(userId);
          allow create, update, delete: if false;
        }
      }

      match /broadcast_notifications/{notificationId} {
        allow read: if canUseWestory();
        allow create, update, delete: if false;
      }

      match /calendar/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /notices/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin() || isTeacherRole();
      }

      match /curriculum/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /lessons/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /map_resources/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /quiz_questions/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /history_classrooms/{docId} {
        allow read: if canReadHistoryClassroomResource(resource.data);
        allow write: if canWriteHistoryClassroomResource();
      }

      match /history_classroom_results/{docId} {
        allow read: if canReadHistoryClassroomResult(resource.data);
        allow create: if isValidHistoryClassroomResultCreate();
        allow update, delete: if isAdmin();
      }

      match /assessment_config/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin() || isTeacherRole();
      }

      match /grading_plans/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /exam_config/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /quiz_results/{resultId} {
        allow read: if canReadQuizResult(resource.data);
        allow create: if isValidQuizResultCreate();
        allow update, delete: if isAdmin();
      }

      match /quiz_submissions/{docId} {
        allow read: if canReadQuizSubmission(resource.data);
        allow create: if isAdmin() || isValidQuizSubmissionCreate();
        allow update: if isAdmin() || isValidQuizSubmissionUpdate();
        allow delete: if isAdmin();
      }

      match /think_cloud_state/{docId} {
        allow read: if canUseWestory();
        allow write: if isAdmin();
      }

      match /lesson_progress/{userId} {
        allow read, write: if canUseWestory() && (request.auth.uid == userId || isAdmin());

        match /units/{unitId} {
          allow read, write: if canUseWestory() && (request.auth.uid == userId || isAdmin());
        }
      }

      match /lesson_presentations/{unitId}/teachers/{userId} {
        allow read, write: if isAdmin() || (canUseWestory() && request.auth.uid == userId && hasPermission('lesson_read'));

        match /classes/{classId} {
          allow read, write: if isAdmin() || (canUseWestory() && request.auth.uid == userId && hasPermission('lesson_read'));
        }
      }

      match /think_cloud_sessions/{sessionId} {
        allow read: if canAccessThinkCloudTarget(resource.data.targetGrade, resource.data.targetClass);
        allow create, update, delete: if isAdmin();

        match /responses/{responseId} {
          allow read: if canAccessThinkCloudTarget(
            get(/databases/$(database)/documents/years/$(year)/semesters/$(semester)/think_cloud_sessions/$(sessionId)).data.targetGrade,
            get(/databases/$(database)/documents/years/$(year)/semesters/$(semester)/think_cloud_sessions/$(sessionId)).data.targetClass
          );
          allow create: if isValidSemesterThinkCloudResponseCreate(year, semester, sessionId);
          allow update, delete: if isAdmin();
        }
      }
    }
  }
}
